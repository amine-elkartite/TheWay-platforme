# THEWAY API environment
NODE_ENV=development
PORT=3001
APP_BASE_URL=http://localhost:3001
CLIENT_BASE_URL=http://localhost:3001

# Raw MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=theway
DB_PASSWORD=theway_dev_password
DB_NAME=theway
DB_SSL=false

# Secure browser sessions
COOKIE_SECRET=replace-with-at-least-32-random-characters
CSRF_SECRET=replace-with-at-least-32-random-characters
SESSION_TTL_DAYS=14
CORS_ORIGIN=http://localhost:3001,http://127.0.0.1:3001

# LLM matching/CV analysis. Production/staging should configure these.
AI_PROVIDER=openai-compatible
AI_API_KEY=replace-with-provider-key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# OAuth/OIDC social login
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_LINKEDIN_CLIENT_ID=
OAUTH_LINKEDIN_CLIENT_SECRET=

# Transactional email
MAIL_PROVIDER=smtp
MAIL_FROM=no-reply@theway.example
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Upload storage
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=storage/uploads
MAX_FILE_SIZE=20971520
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Seed bootstrap. Local seed defaults to admin@theway.local / ChangeMe12345! if omitted.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Observability
OTEL_SERVICE_NAME=theway-api
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
