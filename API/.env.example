# TheWay API Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=theway
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_key_here_change_in_production
JWT_EXPIRY=7d

# CORS Configuration
CORS_ORIGIN=*

# File Upload Configuration
UPLOAD_DIR=assets/uploads
MAX_FILE_SIZE=52428800

# API Configuration
API_BASE_URL=http://localhost:3001

# Email Configuration (Optional - for password recovery)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@theway.com

# Social Login Configuration (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Payment Configuration (Optional)
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/theway.log

# Session Configuration
SESSION_SECRET=your_session_secret_key
SESSION_MAX_AGE=604800000

# Feature Flags
ENABLE_SOCIAL_LOGIN=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_PAYMENT=false
ENABLE_AI_MATCHING=false
